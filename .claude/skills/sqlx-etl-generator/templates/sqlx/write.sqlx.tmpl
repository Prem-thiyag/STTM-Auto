    "stage": "write",
    "buildspec": "{{ buildspec_path }}",
    "database": "{{ target_database }}",
    "version": "{{ sqlx_version }}"
}

-- Generated by sqlx-etl-generator · DO NOT EDIT BY HAND
-- Hand edits will be flagged as drift by the Review plan (see metadata/manifest.json).
--
-- Stage:         write
-- Target table:  {{ target_table }}
-- Run against:   {{ target_database }}
-- Load strategy: {{ load_strategy }}
-- Reads through: {{ fdw_alias(intermediate_database) }} (foreign schema set up in bootstrap/db/01_init)

{% if load_strategy == 'full_load' %}
-- CASCADE: {{ target_table }} may be referenced by another target table's FK (e.g. a
-- dimension referenced by a fact). Every target table is independently truncated and
-- fully reloaded by its own write.sqlx under full_load, so a CASCADE-triggered truncate
-- of a dependent table here is always safe -- that table gets its own truncate+reload
-- when its own write.sqlx runs (see metadata/dependency/dependency_graph.json's
-- execution_order). Without CASCADE, PostgreSQL refuses to truncate any table an FK
-- references, regardless of whether the referencing table currently has rows.
TRUNCATE TABLE {{ target_table }} CASCADE;

INSERT INTO {{ target_table }} (
{{ target_column_list }}
)
SELECT
{{ target_column_list }}
FROM {{ fdw_alias(intermediate_database) }}.{{ staging_table }};
{% endif %}
