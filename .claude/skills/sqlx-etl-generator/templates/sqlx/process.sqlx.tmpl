config {
    "stage": "process",
    "buildspec": "{{ buildspec_path }}",
    "database": "{{ intermediate_database }}",
    "version": "{{ sqlx_version }}"
}

-- Generated by sqlx-etl-generator · DO NOT EDIT BY HAND
-- Hand edits will be flagged as drift by the Review plan (see metadata/manifest.json).
--
-- Stage:         process
-- Target table:  {{ target_table }}
-- Run against:   {{ intermediate_database }}
--
-- Resolves LOOKUP-typed column mappings, each of which references data already written
-- by an earlier stage per metadata/dependency/dependency_graph.json's execution_order.
-- All other column types (DIRECT, EXPRESSION, UDF, CONSTANT) were already resolved by
-- read.sqlx and require no further processing here.

{% if lookup_columns %}
{% for c in lookup_columns %}
UPDATE {{ intermediate_schema }}.{{ staging_table }}
SET {{ c.target_column }} = {{ c.expression }};
{% endfor %}
{% else %}
-- No LOOKUP-typed columns in this table's build specification; no cross-table
-- resolution is required at process time.
{% endif %}
SELECT count(*) AS row_count FROM {{ intermediate_schema }}.{{ staging_table }};
