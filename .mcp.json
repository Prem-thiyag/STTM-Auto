{
  "mcpServers": {
    "postgres": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "envmcp",
        "-e",
        ".env.mcp",
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "%DATABASE_URL%"
      ]
    }
  }
}